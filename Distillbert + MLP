    "def preprocess_for_eda(text: str) -> str:\n",
    "    \"\"\"\n",
    "    Preprocessing agresif untuk keperluan EDA.\n",
    "    - Lowercase\n",
    "    - Hapus URL, mention, hashtag, karakter khusus\n",
    "    - Hapus angka\n",
    "    - Hapus extra whitespace\n",
    "    \"\"\"\n",
    "    text = str(text).lower()\n",
    "    text = re.sub(r'http\\S+|www\\S+', '', text)          # URL\n",
    "    text = re.sub(r'@\\w+|#\\w+', '', text)               # mention & hashtag\n",
    "    text = re.sub(r'[^a-z\\s]', ' ', text)               # karakter non-alfabet\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()            # extra whitespace\n",
    "    return text\n",
    "\n",
    "\n",
    "def preprocess_for_bert(text: str) -> str:\n",
    "    \"\"\"\n",
    "    Preprocessing minimal untuk input DistilBERT.\n",
    "    Hanya hapus karakter yang sangat noisy.\n",
    "    Pertahankan tanda baca & huruf besar (membantu BERT memahami konteks).\n",
    "    \"\"\"\n",
    "    text = str(text)\n",
